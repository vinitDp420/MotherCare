# ─────────────────────────────────────────────────────────────────────────────
# MotherCare Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ──────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-me-in-production-use-at-least-50-chars

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mothercare_user:mothercare_secret@localhost:5432/mothercare

# Individual parts (used as fallback if DATABASE_URL is not set)
POSTGRES_DB=mothercare
POSTGRES_USER=mothercare_user
POSTGRES_PASSWORD=mothercare_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── File Storage ─────────────────────────────────────────────────────────────
# Options: local | s3
STORAGE_BACKEND=local

# AWS S3 (only required when STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=ap-south-1

# ── Security ─────────────────────────────────────────────────────────────────
# Session token validity in hours (default: 8h active, 720h = 30 days with remember-me)
SESSION_TOKEN_EXPIRY_HOURS=8
SESSION_REMEMBER_ME_EXPIRY_HOURS=720

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Hospital ─────────────────────────────────────────────────────────────────
HOSPITAL_CODE=SH-MAT-2024

# ── Email (MVP: console backend) ─────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ── SMS (MVP: stub) ──────────────────────────────────────────────────────────
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
